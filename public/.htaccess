<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Force HTTPS (optional, recommended for Razorhost cPanel)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Rule for routing all /api/something requests cleanly to api.php?route=something
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^api/(.*)$ api.php?route=$1 [QSA,L]

    # Ensure clean Vite Single Page App routing in cPanel
    # If the file or directory exists, serve it directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Redirect all other non-existing URLs to index.html for React Router to handle
    RewriteRule ^ index.html [L]
</IfModule>
